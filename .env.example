# Configuration Template
# Same .env works for: local testing + docker-compose + make run
# localhost is overridden to host.docker.internal in docker-compose

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# MCP Server configuration
AUTH_TOKEN=your-secret-token-here
DEV_MODE=false
# ALLOWED_SCHEMA=my_schema

# dbt configuration
DBT_POSTGRES_HOST=localhost
DBT_POSTGRES_PORT=5432
DBT_POSTGRES_DATABASE=postgres
DBT_POSTGRES_USER=postgres
DBT_POSTGRES_PASSWORD=postgres
DBT_POSTGRES_SCHEMA=public
DBT_POSTGRES_THREADS=4

# MCP Server URL
MCP_SERVER_URL=http://localhost:9001/mcp/
MCP_AUTH_TOKEN=your-secret-token-here
